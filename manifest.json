{
    "manifest_version": 3,
    "name": "Lead Vault",
    "description": "A polished lead tracking extension to capture and manage useful URLs from your browsing sessions.",
    "version": "3.0.0",
    "action": {
        "default_title": "Lead Vault",
        "default_popup": "index.html",
        "default_icon": {
            "16": "logo.png",
            "48": "logo.png",
            "128": "logo.png"
        }
    },
    "icons": {
        "16": "logo.png",
        "48": "logo.png",
        "128": "icon.png"
    },
    "permissions": [
        "tabs",
        "storage"
    ]
}
